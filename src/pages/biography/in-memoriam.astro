---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="In Memoriam">
  <h1>In Memoriam</h1>

  <figure>
    <img src="/images/with-phoebe-at-trebbio.jpg" alt="Paul Sapieha with Phoebe at Trebbio">
    <figcaption>With Phoebe at Trebbio</figcaption>
  </figure>

  <h2>Lord Thomas&rsquo; Eulogy</h2>

  <figure>
    <img src="/images/lord-thomas-eulogy.jpg" alt="Lord Thomas' Eulogy for Paul Sapieha">
    <figcaption>Lord Thomas&rsquo; Eulogy</figcaption>
  </figure>

  <h2>Newspaper Announcements</h2>

  <div class="image-row">
    <figure>
      <img
        src="https://paulsapieha.wordpress.com/wp-content/uploads/2021/01/telegraph20memorial20notice.jpg"
        alt="Telegraph memorial notice"
      >
      <figcaption>Telegraph memorial notice</figcaption>
    </figure>
    <figure>
      <img
        src="https://paulsapieha.wordpress.com/wp-content/uploads/2021/01/polish20announcement.jpg"
        alt="Polish announcement"
      >
      <figcaption>Polish announcement</figcaption>
    </figure>
    <figure>
      <img
        src="https://paulsapieha.wordpress.com/wp-content/uploads/2021/01/img_0356.jpg"
        alt="Memorial notice"
      >
      <figcaption>Memorial notice</figcaption>
    </figure>
  </div>
</Layout>
